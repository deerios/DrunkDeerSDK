@using System.Globalization
@using DrunkDeer.Protocol
@inject KeyboardService Keyboard
@inject KeyboardStore Store
@inject SelectionStore Selection
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@implements IDisposable

@* The actuation side panel (FUTURE_PLAN §5.4): edits the actuation point of whatever is
   selected on the on-screen keyboard. See KeyboardService.ApplyActuationAsync for why the
   baseline for unselected keys is asked for up front rather than assumed. *@

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-1">Actuation</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        How far a key travels before it registers.
    </MudText>

    <MudDivider Class="my-3" />

    @if (Selection.IsEmpty)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Select keys on the keyboard to set their actuation point.
        </MudText>
    }
    else
    {
        <MudText Typo="Typo.body2" Class="mb-1">
            <b>@Selection.Count</b> @(Selection.Count == 1 ? "key" : "keys") selected
        </MudText>
        <MudSlider T="float" Value="_depthMm" ValueChanged="OnDepthChanged"
                   Min="@Keyboard.MinDepthMm" Max="@Keyboard.MaxDepthMm"
                   Step="0.05f" Immediate="true" Class="mt-2"
                   ValueLabel="true" Disabled="@_busy">
            @Mm(_depthMm)
        </MudSlider>
        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
            The marker on each selected key shows where this lands. Apply to write it to the board.
        </MudText>

        @if (_depthMm > SafeMaxDepthMm)
        {
            <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                Above @Mm(SafeMaxDepthMm) some switches may never register. @Mm(_depthMm) is close to the
                bottom of the key's travel.
            </MudAlert>
        }

        @if (!Keyboard.DepthsAreKnown)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                This board can't report its current settings, and the firmware only accepts
                whole-board writes — so applying also sets every key you didn't select.
            </MudAlert>
            <MudNumericField T="float" @bind-Value="_baselineMm" Label="All other keys"
                             Min="@Keyboard.MinDepthMm" Max="@Keyboard.MaxDepthMm" Step="0.05f"
                             Adornment="Adornment.End" AdornmentText="mm" Format="0.00"
                             Culture="@CultureInfo.InvariantCulture"
                             Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-3"
                             Disabled="@_busy" />
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-3">
                Keys you haven't selected keep the values this session last wrote.
            </MudText>
        }

        <MudButton Class="mt-3" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save" Disabled="@_busy" OnClick="ApplyAsync">
            @(_busy ? "Applying…" : "Apply to keyboard")
        </MudButton>
    }

    <MudDivider Class="my-4" />

    <MudSwitch T="bool" Value="@Keyboard.RapidTriggerEnabled" ValueChanged="ToggleRapidTriggerAsync"
               Color="Color.Primary" Disabled="@_busy" Label="Rapid trigger" />
    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
        Registers each press and release from the direction of travel rather than a fixed point.
        Applies to the whole board.
    </MudText>
</MudPaper>

@code {
    // Depths above this are legal but risky: the SDK warns at the same threshold because a key
    // set this deep may never reach its actuation point.
    private const float SafeMaxDepthMm = 3.3f;

    private float _depthMm = 2.0f;
    private float _baselineMm = 2.0f;
    private bool _busy;

    protected override void OnInitialized()
    {
        Selection.Changed += OnSelectionChanged;
        _depthMm = Math.Clamp(_depthMm, Keyboard.MinDepthMm, Keyboard.MaxDepthMm);
        _baselineMm = _depthMm;
        PublishPreview();
    }

    private void OnDepthChanged(float mm)
    {
        _depthMm = mm;
        PublishPreview();
    }

    // The board draws the pending depth on the selected keys, so it has to hear about the slider
    // as it moves. Nothing is selected means nothing is being edited, so the board shows no preview.
    private void PublishPreview() =>
        Keyboard.SetActuationPreview(Selection.IsEmpty ? null : _depthMm);

    private async Task ApplyAsync()
    {
        var keys = SelectedKeys();
        if (keys.Length == 0) return;

        // Only the first write of a session needs confirming: it is the one that writes a value
        // to keys the user never touched. After that the panel leaves them alone.
        if (!Keyboard.DepthsAreKnown && !await ConfirmFirstWriteAsync(keys.Length))
            return;

        _busy = true;
        try
        {
            await Keyboard.ApplyActuationAsync(_depthMm, keys, _baselineMm);
            Snackbar.Add($"Set {keys.Length} {(keys.Length == 1 ? "key" : "keys")} to {Mm(_depthMm)}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't apply actuation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task<bool> ConfirmFirstWriteAsync(int selected)
    {
        int others = Math.Max(0, (Keyboard.Session?.Layout.Count ?? 0) - selected);
        var body = Store.IsDemo
            ? $"Sets {selected} selected {Noun(selected)} to {Mm(_depthMm)} and the other {others} to {Mm(_baselineMm)}. "
              + "This is a simulated keyboard, so no hardware is touched."
            : $"Sets {selected} selected {Noun(selected)} to {Mm(_depthMm)} and the other {others} to {Mm(_baselineMm)}. "
              + "This board's existing settings can't be read back, so anything configured elsewhere "
              + "(for example in the official app) will be overwritten.";

        var result = await Dialogs.ShowMessageBoxAsync(
            title: "Apply to the whole keyboard?",
            markupMessage: new MarkupString(body),
            yesText: "Apply", cancelText: "Cancel");
        return result == true;
    }

    private async Task ToggleRapidTriggerAsync(bool enabled)
    {
        _busy = true;
        try
        {
            await Keyboard.SetRapidTriggerAsync(enabled);
            Snackbar.Add($"Rapid trigger {(enabled ? "on" : "off")}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't change rapid trigger: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // The selection is held as firmware slots; the SDK's actuation API speaks DDKey, and the
    // layout is what maps between them.
    private DDKey[] SelectedKeys()
    {
        var session = Keyboard.Session;
        if (session is null) return [];
        return [.. session.Layout.Where(k => Selection.Contains(k.SlotIndex)).Select(k => k.Key)];
    }

    private void OnSelectionChanged() => _ = InvokeAsync(() =>
    {
        PublishPreview();
        StateHasChanged();
    });

    private static string Noun(int n) => n == 1 ? "key" : "keys";

    private static string Mm(float v) => v.ToString("0.00", CultureInfo.InvariantCulture) + " mm";

    // Switching to another tab disposes this panel, and a depth nobody is editing any more
    // shouldn't stay painted on the board.
    public void Dispose()
    {
        Selection.Changed -= OnSelectionChanged;
        Keyboard.SetActuationPreview(null);
    }
}
